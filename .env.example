# Copy to .env to override defaults locally. All settings are optional —
# the system runs with sensible defaults out of the box. Prefix is OJ_.

# --- Persistence ---------------------------------------------------------
# SQLite by default. For production, point at PostgreSQL, e.g.:
#   OJ_DATABASE_URL=postgresql+psycopg://user:pass@localhost/judge
OJ_DATABASE_URL=sqlite:///./judge.db

# --- Sandbox -------------------------------------------------------------
OJ_SANDBOX_IMAGE=online-judge-sandbox:latest
OJ_DOCKER_BINARY=docker
OJ_RUN_ROOT=/tmp/oj-runs

# --- Default problem limits (overridable per problem) --------------------
OJ_DEFAULT_TIME_LIMIT_MS=2000
OJ_DEFAULT_MEMORY_LIMIT_MB=256
OJ_DEFAULT_OUTPUT_LIMIT_KB=256

# --- Sandbox enforcement -------------------------------------------------
OJ_DOCKER_CPUS=1.0
OJ_PIDS_LIMIT=128
OJ_OPEN_FILES_LIMIT=256
OJ_TMPFS_SIZE_MB=64
OJ_SANDBOX_USER=1000:1000
OJ_MEMORY_OVERHEAD_MB=64
OJ_WALL_TIME_GRACE_MS=500
OJ_CONTAINER_STARTUP_GRACE_S=8.0

# --- Worker pool / queue -------------------------------------------------
OJ_WORKER_COUNT=2
OJ_WORKER_POLL_INTERVAL_S=0.5
OJ_STALE_CLAIM_TIMEOUT_S=300
OJ_FAIL_FAST=true
